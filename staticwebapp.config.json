{
  "platform": {
    "apiRuntime": "dotnet-isolated:9.0"
  },
  "navigationFallback": {
    "rewrite": "/200.html",
    "exclude": [
      "*.{png,jpg,gif,svg,css,js,json,xml,txt,ico,woff,woff2,ttf,eot}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "routes": [
    {
      "route": "/pages/portfolio",
      "redirect": "/content/20-portfolio",
      "statusCode": 301
    },
    {
      "route": "/pages/about",
      "redirect": "/content/30-about",
      "statusCode": 301
    }
  ]
}
